{
  "expo": {
    "name": "Calorfy",
    "slug": "calorfy-lite",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "calorfy",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.calorfy.calorfylite",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Calorfy usa la cámara para analizar las comidas que elijas fotografiar.",
        "NSPhotoLibraryUsageDescription": "Calorfy accede a las fotos que elijas para analizar tus comidas."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.calorfy.calorfylite"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F3F7F5",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#0B1713"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "5ffa5f5f-9dc7-490e-b21e-cb5420b9c349"
      }
    },
    "owner": "calorfy"
  }
}
